# --- Postgres warehouse (read/write role, used for migrations + seeding) ---
DATABASE_URL=postgres://chatty:chatty@localhost:5433/chatty

# --- Read-only role used for executing planned queries (least privilege) ---
DATABASE_URL_RO=postgres://chatty_ro:chatty_ro@localhost:5433/chatty

# --- Redis (SQL-fingerprint result cache) ---
REDIS_URL=redis://localhost:6380

# --- sqlglot validator sidecar ---
VALIDATOR_URL=http://127.0.0.1:7070

# --- LLM (planner). Confirm model ids/params via the claude-api skill. ---
ANTHROPIC_API_KEY=
PLANNER_MODEL=claude-opus-4-8
ROUTER_MODEL=claude-haiku-4-5-20251001

# --- Embeddings for schema-linking (Voyage; Anthropic's recommended provider) ---
VOYAGE_API_KEY=
EMBEDDING_MODEL=voyage-3-large

# --- Query execution guards ---
QUERY_STATEMENT_TIMEOUT_MS=15000
QUERY_ROW_LIMIT=5000

# --- Stripe connector (test mode). Leave blank to use the synthetic seed. ---
STRIPE_SECRET_KEY=
