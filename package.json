{
  "name": "chatty",
  "version": "0.1.0",
  "private": true,
  "description": "Correctness-first finance analyst: semantic-layer planning + sqlglot-validated read-only SQL with full provenance.",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "db:migrate": "pnpm --filter @chatty/db migrate",
    "db:seed": "pnpm --filter @chatty/db seed",
    "eval": "pnpm --filter @chatty/eval eval",
    "infra:up": "docker compose -f infra/docker-compose.yml up -d",
    "infra:down": "docker compose -f infra/docker-compose.yml down",
    "validator": "python -m uvicorn validator.app:app --app-dir packages/validator --host 127.0.0.1 --port 7070",
    "dev:api": "pnpm --filter @chatty/api dev",
    "dev:web": "pnpm --filter @chatty/web dev"
  },
  "devDependencies": {
    "@types/node": "^22.7.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
